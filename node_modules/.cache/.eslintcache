","messages":"102","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"D:\\firebaseTanu\\my-app\\src\\index.js",[],"D:\\firebaseTanu\\my-app\\src\\App.js",["103","104","105"],"import React,{useEffect} from 'react';\nimport Nav from \"./Nav\";\nimport Side from \"./SideNav\";\nimport {Switch,Route} from \"react-router-dom\";\nimport Services from \"./Services\";\nimport Home from \"./Home\";\nimport About from \"./About\";\nimport Footer from \"./Footer\";\nimport Contact from \"./Contact\";\nimport ExtraDetails from \"./ExtraDetails\";\nimport MainService from \"./MainService\";\nimport PropertyMiniDetailes from \"./PropertyMiniDetailes\";\nimport Error from \"./Error\";\nimport PaymentInfo from \"./PaymentInfo\";\nimport { createMuiTheme, makeStyles, ThemeProvider } from '@material-ui/core/styles';\nimport {Provider} from \"react-redux\";\nimport store from \"./redux/store\"\nimport{darkMode} from \"./redux\"\nimport {connect} from \"react-redux\"\nimport Paper from \"@material-ui/core/Paper\"\nimport ChatBot from \"./ChatBot\"\n\nfunction App(props) {\n\n  store.subscribe(() => {\n    localStorage.setItem('reduxStore' , JSON.stringify(store.getState()));\n    // console.log(store.getState().login.data.token)\n  })\n    const theme = createMuiTheme({\n      palette: {\n        type:JSON.parse(localStorage.getItem(\"reduxStore\")).mode,\n      },\n    });\n\n\n  return (  \n    <>\n\n<Provider store={store}>\n  <ThemeProvider theme={theme}>\n  <Paper>\n<Nav/>\n<ChatBot/>\n    <Side/>\n\n    \n    <Switch>\n    \n    <Route exact path=\"/\" component={Home} />\n    <Route exact path=\"/about\" component={About} />\n    <Route exact path=\"/services\" component={Services} />\n    <Route exact path=\"/services/details\" component={MainService} />\n    <Route exact path=\"/services/details/:idd\" component={PropertyMiniDetailes} />\n    <Route exact path=\"/services/:id\" component={ExtraDetails} />\n    <Route exact path=\"/contact\" component={Contact} />\n    <Route exact path=\"/paymentinfo\" component={PaymentInfo} />\n\n    <Route exact path=\"*\" component={Error} />\n\n    </Switch>\n\n    {/* DARKMODE */}\n      \n    <button style={{border:\"1px solid #CDBA6D\",transform:\"rotate(90deg)\",backgroundColor:\"rgba(1,1,1,0.6)\",color:\"white\",position:\"fixed\",top:\"220px\",height:\"25px\",left:\"0\",width:\"7rem\",borderRadius:\"6px 0px 0 0\",left:\"-16px\"}} onClick={()=>props.darkMode(\"light\")}><b>light</b></button><br/><br/>\n    <button  style={{border:\"1px solid #CDBA6D\",transform:\"rotate(90deg)\",backgroundColor:\"rgba(1,1,1,0.6)\",color:\"white\",position:\"fixed\",top: '-webkit-calc(220px + 7rem)' ,height:\"25px\",left:\"-16px\",width:\"7rem\",borderRadius:\"0px 6px 0 0\"}}  onClick={()=>props.darkMode(\"dark\")}><b>dark</b></button>\n    {/* DARKMODE */}\n\n<Footer/> \n</Paper>\n</ThemeProvider>\n</Provider>\n    </>\n  );\n}\n\nconst mapStatetoProps=(state)=>{\n\n  return{\n    mode:state.mode\n  }\n  \n  }\n  \n  \n  const mapDispatchToProps=(dispatch)=>{\n  return{\n    darkMode:function(light){ \n      dispatch(darkMode(light));\n    }\n  }\n  }\nexport default  connect(mapStatetoProps,mapDispatchToProps) (App);\n","D:\\firebaseTanu\\my-app\\src\\redux\\store.js",[],"D:\\firebaseTanu\\my-app\\src\\redux\\dark\\darkReducer.js",[],"D:\\firebaseTanu\\my-app\\src\\SideNav.jsx",[],"D:\\firebaseTanu\\my-app\\src\\Nav.jsx",["106","107","108","109","110","111","112"],"D:\\firebaseTanu\\my-app\\src\\Services.jsx",["113"],"D:\\firebaseTanu\\my-app\\src\\Home.jsx",["114","115"],"D:\\firebaseTanu\\my-app\\src\\About.jsx",["116"],"D:\\firebaseTanu\\my-app\\src\\Footer.jsx",["117","118","119","120","121"],"D:\\firebaseTanu\\my-app\\src\\Contact.jsx",["122","123","124","125","126","127","128","129","130"],"D:\\firebaseTanu\\my-app\\src\\ExtraDetails.jsx",["131"],"D:\\firebaseTanu\\my-app\\src\\MainService.jsx",[],"D:\\firebaseTanu\\my-app\\src\\PropertyMiniDetailes.jsx",["132"],"D:\\firebase